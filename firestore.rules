rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers --------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // Anyone with a doc in admins/ is at least a sub-admin.
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    // Super-admins additionally have role == "super" (or no role field, for
    // backwards compatibility with admins created before roles existed).
    function isSuper() {
      return isAdmin() && (
        !( "role" in get(/databases/$(database)/documents/admins/$(request.auth.uid)).data )
        || get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "super"
      );
    }

    // ---------------------------------------------------------------- users
    // A user reads/writes their own user document. Admins (any tier) can read
    // any user for the admin user-list. Only supers can edit identity fields
    // via cloud function — never via this rule.
    match /users/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid);
    }

    // ---------------------------------------------------------------- scans
    // Each scan carries its owner uid. Owners read/write their own scans.
    // Admins can read everyone's scans for stats / curation purposes.
    match /scans/{scanId} {
      allow read:   if isOwner(resource.data.uid) || isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isOwner(resource.data.uid);
    }

    // ---------------------------------------------------------------- ads
    // Every signed-in user can fetch the active ad list. Sub-admins and
    // super-admins can edit.
    match /ads/{adId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ----------------------------------------------------- featured_products
    match /featured_products/{productId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------- stats_daily
    // Stats are written exclusively by a privileged Cloud Function. Mobile
    // clients can read aggregates only after admin login.
    match /stats_daily/{day} {
      allow read:  if isAdmin();
      allow write: if false; // server-only via the Admin SDK
    }

    // ---------------------------------------------------------------- admins
    // Doc shape: { role: "super" | "sub", grantedBy, grantedAt, label? }
    //   - "super" can grant/revoke any role, including other supers.
    //   - "sub"   can edit ads + read users, but not edit the admins/ list.
    //   - Missing role → treated as "super" (back-compat with pre-role docs).
    //
    // Bootstrap window: while bootstrap/done does NOT exist yet, any signed-in
    // user may create their own admins/{uid} doc once. The web admin's
    // self-promote button writes that admin doc + the bootstrap sentinel
    // atomically, slamming the window shut for everyone else.
    match /admins/{uid} {
      allow get:    if isOwner(uid) || isAdmin();
      allow list:   if isAdmin();
      allow create: if isSuper() || (
                      isOwner(uid)
                      && !exists(/databases/$(database)/documents/bootstrap/done)
                    );
      allow update, delete: if isSuper();
    }

    // ---------------------------------------------------------------- stories
    // Reader-contributed posts (stories and recipes). Two key fields:
    //   - uid:       author's auth uid (set on create, immutable thereafter)
    //   - published: boolean; admins can flip to hide.
    //   - featured:  boolean; admins toggle to spotlight on the Stories page.
    //
    // Read model: published==true is public to anyone (even logged out, so the
    // Stories page works for non-members). Authors can read their own hidden
    // posts. Admins can read everything.
    //
    // Write model: the author owns content fields; only admins flip
    // featured/published, set moderation fields, and override others' posts.
    match /stories/{storyId} {
      function isAuthor() {
        return isSignedIn() && resource.data.uid == request.auth.uid;
      }
      function payloadIsAuthor() {
        return request.resource.data.uid == request.auth.uid;
      }
      // Whitelist of content fields the author may set/change.
      function authorFields() {
        return [
          "uid","authorName","authorEmail","authorPhotoURL",
          "type","title","body","imageUrl",
          "ingredients","steps","tags",
          "createdAt","updatedAt"
        ];
      }
      // Authors must not touch moderation fields on update.
      function authorChangesOnly() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(authorFields().toSet());
      }

      allow read: if resource.data.published == true
                  || isOwner(resource.data.uid)
                  || isAdmin();
      allow create: if isSignedIn()
                    && payloadIsAuthor()
                    && request.resource.data.published == true
                    && request.resource.data.featured == false;
      allow update: if isAdmin()
                    || (isAuthor() && authorChangesOnly());
      allow delete: if isAdmin() || isAuthor();
    }

    // -------------------------------------------------- bootstrap sentinel
    // Single-doc collection that locks the first-admin self-promote window.
    // Created by the first signed-in user (in the same batch as their own
    // admins/ write), or written defensively by any super-admin sign-in.
    match /bootstrap/{docId} {
      allow read:   if true;
      allow create: if isSignedIn()
                    && !exists(/databases/$(database)/documents/bootstrap/done);
      allow update, delete: if isSuper();
    }
  }
}
